package test.java.br.com.mulato.cso.view.controller;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mock;
import org.mockito.MockedStatic;
import org.mockito.junit.jupiter.MockitoExtension;

import jakarta.faces.context.FacesContext;
import jakarta.faces.context.ExternalContext;
import jakarta.faces.application.Application;
import jakarta.servlet.http.HttpSession;
import jakarta.servlet.http.HttpServletRequest;

import br.com.mulato.cso.view.controller.ChangePasswordController;
import br.com.mulato.cso.view.controller.LoginController;
import br.com.mulato.cso.dry.FactoryService;
import br.com.mulato.cso.service.AdminService;
import br.com.mulato.cso.service.LoginService;
import br.com.mulato.cso.model.UserVO;
import br.com.mulato.cso.model.LoginVO;
import br.com.mulato.cso.exception.WebException;

/**
 * Testes unitários para ChangePasswordController
 * Valida toda a lógica de negócio para troca de senhas
 * 
 * @author Test Suite
 */
@ExtendWith(MockitoExtension.class)
@DisplayName("Testes do ChangePasswordController")
class ChangePasswordControllerTest {

    @Mock
    private FacesContext facesContext;

    @Mock
    private ExternalContext externalContext;

    @Mock
    private Application application;

    @Mock
    private HttpSession session;

    @Mock
    private HttpServletRequest request;

    @Mock
    private LoginController loginController;

    @Mock
    private FactoryService factoryService;

    @Mock
    private AdminService adminService;

    @Mock
    private LoginService loginService;

    private ChangePasswordController changePasswordController;

    @BeforeEach
    void setUp() {
        // Mock do contexto JSF
        when(facesContext.getExternalContext()).thenReturn(externalContext);
        when(facesContext.getApplication()).thenReturn(application);
        when(externalContext.getRequest()).thenReturn(request);
        when(externalContext.getSession(false)).thenReturn(session);
    }

    @Test
    @DisplayName("Deve inicializar o controller corretamente para usuário não-master")
    void deveInicializarControllerCorretamenteParaUsuarioNaoMaster() {
        // Given
        UserVO userVO = createTestUser(false);
        
        try (MockedStatic<FacesContext> mockedFacesContext = mockStatic(FacesContext.class);
             MockedStatic<FactoryService> mockedFactory = mockStatic(FactoryService.class)) {
            
            mockedFacesContext.when(FacesContext::getCurrentInstance).thenReturn(facesContext);
            mockedFactory.when(FactoryService::getInstancia).thenReturn(factoryService);
            
            when(application.evaluateExpressionGet(any(), eq("loginMB"), eq(LoginController.class)))
                    .thenReturn(loginController);
            when(loginController.getProfile()).thenReturn("ADMINISTRATOR");
            when(loginController.getUserIdLogged()).thenReturn(1);
            when(loginController.isMaster()).thenReturn(false);
            when(factoryService.getAdminService()).thenReturn(adminService);
            when(adminService.find(1)).thenReturn(userVO);

            // When
            ChangePasswordController controller = new ChangePasswordController();

            // Then
            assertNotNull(controller);
            assertEquals(Integer.valueOf(1), controller.getId());
            assertEquals("ADMINISTRATOR", controller.getRole());
            assertEquals("Test User", controller.getName());
            assertEquals("test@email.com", controller.getEmail());
            assertEquals("test@email.com", controller.getEmail1());
            assertEquals("alt@email.com", controller.getEmail2());
            assertEquals("testuser", controller.getLogin());
            assertNull(controller.getPassword());
            assertNull(controller.getNewPassword());
            assertNull(controller.getNewRepeat());
            assertTrue(controller.isProfile_to_change());
            assertFalse(controller.isMaster());
        }
    }

    @Test
    @DisplayName("Deve inicializar o controller corretamente para usuário master")
    void deveInicializarControllerCorretamenteParaUsuarioMaster() {
        // Given
        UserVO userVO = createTestUser(true);
        
        try (MockedStatic<FacesContext> mockedFacesContext = mockStatic(FacesContext.class);
             MockedStatic<FactoryService> mockedFactory = mockStatic(FactoryService.class)) {
            
            mockedFacesContext.when(FacesContext::getCurrentInstance).thenReturn(facesContext);
            mockedFactory.when(FactoryService::getInstancia).thenReturn(factoryService);
            
            when(application.evaluateExpressionGet(any(), eq("loginMB"), eq(LoginController.class)))
                    .thenReturn(loginController);
            when(loginController.getProfile()).thenReturn("ADMINISTRATOR");
            when(loginController.getUserIdLogged()).thenReturn(1);
            when(loginController.isMaster()).thenReturn(true);
            when(factoryService.getAdminService()).thenReturn(adminService);
            when(adminService.findGetPasswordTo(1)).thenReturn(userVO);

            // When
            ChangePasswordController controller = new ChangePasswordController();

            // Then
            assertNotNull(controller);
            assertEquals(Integer.valueOf(1), controller.getId());
            assertEquals("ADMINISTRATOR", controller.getRole());
            assertEquals("Test User", controller.getName());
            assertEquals("test@email.com", controller.getEmail());
            assertEquals("testuser", controller.getLogin());
            assertEquals("masterpass", controller.getStrPassword());
            assertTrue(controller.isMaster());
        }
    }

    @Test
    @DisplayName("Deve navegar para página de troca de senha")
    void deveNavegarParaPaginaDeTrocaDeSenha() {
        // Given
        changePasswordController = createMockedController();

        // When
        String resultado = changePasswordController.changePassword();

        // Then
        assertEquals("change_password", resultado);
    }

    @Test
    @DisplayName("Deve cancelar e navegar para página de resumo")
    void deveCancelarENavegacaoParaPaginaDeResumo() {
        // Given
        changePasswordController = createMockedController();

        // When
        String resultado = changePasswordController.cancel();

        // Then
        assertEquals("resume", resultado);
    }

    @Test
    @DisplayName("Deve processar envio de email")
    void deveProcessarEnvioDeEmail() {
        // Given
        changePasswordController = createMockedController();
        setupValidChangePasswordData();

        try (MockedStatic<FactoryService> mockedFactory = mockStatic(FactoryService.class)) {
            mockedFactory.when(FactoryService::getInstancia).thenReturn(factoryService);
            when(factoryService.getLoginService()).thenReturn(loginService);
            doNothing().when(loginService).changePassword(any(LoginVO.class), eq(true));

            // When
            String resultado = changePasswordController.send();

            // Then
            assertNotNull(resultado);
            verify(loginService).changePassword(any(LoginVO.class), eq(true));
        }
    }

    @Test
    @DisplayName("Deve salvar nova senha com validações corretas")
    void deveSalvarNovaSenhaComValidacoesCorretas() {
        // Given
        changePasswordController = createMockedController();
        setupValidChangePasswordData();

        try (MockedStatic<FactoryService> mockedFactory = mockStatic(FactoryService.class)) {
            mockedFactory.when(FactoryService::getInstancia).thenReturn(factoryService);
            when(factoryService.getLoginService()).thenReturn(loginService);
            doNothing().when(loginService).changePassword(any(LoginVO.class), eq(false));

            // When
            String resultado = changePasswordController.save();

            // Then
            assertNotNull(resultado);
            verify(loginService).changePassword(any(LoginVO.class), eq(false));
        }
    }

    @Test
    @DisplayName("Deve lançar exceção quando ID do usuário não informado")
    void deveLancarExcecaoQuandoIdDoUsuarioNaoInformado() {
        // Given
        changePasswordController = createMockedController();
        changePasswordController.setId(null);

        // When & Then
        assertThrows(WebException.class, () -> {
            changePasswordController.save();
        });
    }

    @Test
    @DisplayName("Deve lançar exceção quando perfil não informado")
    void deveLancarExcecaoQuandoPerfilNaoInformado() {
        // Given
        changePasswordController = createMockedController();
        changePasswordController.setId(1);
        changePasswordController.setRole(null);

        // When & Then
        assertThrows(WebException.class, () -> {
            changePasswordController.save();
        });
    }

    @Test
    @DisplayName("Deve lançar exceção quando nova senha não informada")
    void deveLancarExcecaoQuandoNovaSenhaNaoInformada() {
        // Given
        changePasswordController = createMockedController();
        setupBasicValidData();
        changePasswordController.setNewPassword(null);

        // When & Then
        assertThrows(WebException.class, () -> {
            changePasswordController.save();
        });
    }

    @Test
    @DisplayName("Deve lançar exceção quando repetição da nova senha não informada")
    void deveLancarExcecaoQuandoRepeticaoDaNovaSenhaNaoInformada() {
        // Given
        changePasswordController = createMockedController();
        setupBasicValidData();
        changePasswordController.setNewPassword("novaSenha123");
        changePasswordController.setNewRepeat(null);

        // When & Then
        assertThrows(WebException.class, () -> {
            changePasswordController.save();
        });
    }

    @Test
    @DisplayName("Deve lançar exceção quando nova senha e repetição não coincidem")
    void deveLancarExcecaoQuandoNovaSenhaERepeticaoNaoCoincidem() {
        // Given
        changePasswordController = createMockedController();
        setupBasicValidData();
        changePasswordController.setNewPassword("novaSenha123");
        changePasswordController.setNewRepeat("senhasDiferentes");

        // When & Then
        assertThrows(WebException.class, () -> {
            changePasswordController.save();
        });
    }

    @Test
    @DisplayName("Deve validar propriedades getters e setters")
    void deveValidarPropriedadesGettersESetters() {
        // Given
        changePasswordController = new ChangePasswordController();

        // When & Then - testando todos os getters/setters
        changePasswordController.setId(100);
        assertEquals(Integer.valueOf(100), changePasswordController.getId());

        changePasswordController.setRole("BUSINESS");
        assertEquals("BUSINESS", changePasswordController.getRole());

        changePasswordController.setName("João Silva");
        assertEquals("João Silva", changePasswordController.getName());

        changePasswordController.setEmail("joao@email.com");
        assertEquals("joao@email.com", changePasswordController.getEmail());

        changePasswordController.setEmail1("joao1@email.com");
        assertEquals("joao1@email.com", changePasswordController.getEmail1());

        changePasswordController.setEmail2("joao2@email.com");
        assertEquals("joao2@email.com", changePasswordController.getEmail2());

        changePasswordController.setLogin("joaosilva");
        assertEquals("joaosilva", changePasswordController.getLogin());

        changePasswordController.setPassword("senhaAtual");
        assertEquals("senhaAtual", changePasswordController.getPassword());

        changePasswordController.setNewPassword("novaSenha");
        assertEquals("novaSenha", changePasswordController.getNewPassword());

        changePasswordController.setStrPassword("senhaString");
        assertEquals("senhaString", changePasswordController.getStrPassword());

        changePasswordController.setNewRepeat("repetirSenha");
        assertEquals("repetirSenha", changePasswordController.getNewRepeat());

        changePasswordController.setProfile_to_change(true);
        assertTrue(changePasswordController.isProfile_to_change());

        changePasswordController.setMaster(true);
        assertTrue(changePasswordController.isMaster());
    }

    @Test
    @DisplayName("Deve criar LoginVO corretamente na operação save")
    void deveCriarLoginVOCorretamenteNaOperacaoSave() {
        // Given
        changePasswordController = createMockedController();
        setupValidChangePasswordData();

        try (MockedStatic<FactoryService> mockedFactory = mockStatic(FactoryService.class)) {
            mockedFactory.when(FactoryService::getInstancia).thenReturn(factoryService);
            when(factoryService.getLoginService()).thenReturn(loginService);
            
            // Capturar o LoginVO passado para o service
            doNothing().when(loginService).changePassword(any(LoginVO.class), eq(false));

            // When
            changePasswordController.save();

            // Then
            verify(loginService).changePassword(argThat(loginVO -> 
                loginVO.getLogin().equals("testuser") &&
                loginVO.getPassword().equals("senhaAtual") &&
                loginVO.getNewPassword().equals("novaSenha123") &&
                loginVO.getNewRepeat().equals("novaSenha123") &&
                loginVO.getEmail().equals("test@email.com")
            ), eq(false));
        }
    }

    @Test
    @DisplayName("Deve validar diferentes perfis de usuário")
    void deveValidarDiferentesPerfisDeusuario() {
        // Testar com diferentes perfis
        String[] validProfiles = {"ADMINISTRATOR", "BUSINESS", "CUSTOMER"};
        
        for (String profile : validProfiles) {
            UserVO userVO = createTestUser(false);
            
            try (MockedStatic<FacesContext> mockedFacesContext = mockStatic(FacesContext.class);
                 MockedStatic<FactoryService> mockedFactory = mockStatic(FactoryService.class)) {
                
                mockedFacesContext.when(FacesContext::getCurrentInstance).thenReturn(facesContext);
                mockedFactory.when(FactoryService::getInstancia).thenReturn(factoryService);
                
                when(application.evaluateExpressionGet(any(), eq("loginMB"), eq(LoginController.class)))
                        .thenReturn(loginController);
                when(loginController.getProfile()).thenReturn(profile);
                when(loginController.getUserIdLogged()).thenReturn(1);
                when(loginController.isMaster()).thenReturn(false);
                when(factoryService.getAdminService()).thenReturn(adminService);
                when(adminService.find(1)).thenReturn(userVO);

                // When
                ChangePasswordController controller = new ChangePasswordController();

                // Then
                assertTrue(controller.isProfile_to_change(), 
                        "Perfil " + profile + " deve permitir troca de senha");
            }
        }
    }

    @Test
    @DisplayName("Deve tratar perfil inválido corretamente")
    void deveTratarPerfilInvalidoCorretamente() {
        try (MockedStatic<FacesContext> mockedFacesContext = mockStatic(FacesContext.class);
             MockedStatic<FactoryService> mockedFactory = mockStatic(FactoryService.class)) {
            
            mockedFacesContext.when(FacesContext::getCurrentInstance).thenReturn(facesContext);
            mockedFactory.when(FactoryService::getInstancia).thenReturn(factoryService);
            
            when(application.evaluateExpressionGet(any(), eq("loginMB"), eq(LoginController.class)))
                    .thenReturn(loginController);
            when(loginController.getProfile()).thenReturn("INVALID_PROFILE");

            // When
            ChangePasswordController controller = new ChangePasswordController();

            // Then
            assertFalse(controller.isProfile_to_change(), 
                    "Perfil inválido não deve permitir troca de senha");
        }
    }

    private ChangePasswordController createMockedController() {
        ChangePasswordController controller = new ChangePasswordController();
        return controller;
    }

    private UserVO createTestUser(boolean withPassword) {
        UserVO userVO = new UserVO();
        userVO.setId(1);
        userVO.setRole("ADMINISTRATOR");
        userVO.setName("Test User");
        userVO.setEmail("test@email.com");
        userVO.setEmail2("alt@email.com");
        
        if (withPassword) {
            LoginVO loginVO = new LoginVO();
            loginVO.setLogin("testuser");
            loginVO.setPassword("masterpass");
            userVO.setLogin(loginVO);
        } else {
            LoginVO loginVO = new LoginVO();
            loginVO.setLogin("testuser");
            userVO.setLogin(loginVO);
        }
        
        return userVO;
    }

    private void setupBasicValidData() {
        changePasswordController.setId(1);
        changePasswordController.setRole("ADMINISTRATOR");
        changePasswordController.setEmail("test@email.com");
        changePasswordController.setEmail1("test@email.com");
    }

    private void setupValidChangePasswordData() {
        setupBasicValidData();
        changePasswordController.setLogin("testuser");
        changePasswordController.setPassword("senhaAtual");
        changePasswordController.setNewPassword("novaSenha123");
        changePasswordController.setNewRepeat("novaSenha123");
    }
}
