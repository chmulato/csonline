	<!-- CONVERTERS -->
	<converter>
		<converter-id>CpfCnpjConverter</converter-id>
		<converter-class>br.com.mulato.cso.view.converter.CpfCnpjConverter</converter-class>
	</converter>
	<converter>
		<converter-id>CMC7Converter</converter-id>
		<converter-class>br.com.mulato.cso.view.converter.CMC7Converter</converter-class>
	</converter>
	<converter>
		<converter-id>CEPConverter</converter-id>
		<converter-class>br.com.mulato.cso.view.converter.CEPConverter</converter-class>
	</converter>
	<converter>
		<converter-id>BigDecimalConverter</converter-id>
		<converter-class>br.com.mulato.cso.view.converter.BigDecimalConverter</converter-class>
	</converter>

	<!-- VALIDATIONS -->
	<validator>
		<validator-id>validaEmail</validator-id>
		<validator-class>br.com.mulato.cso.view.validation.EmailValidation</validator-class>
	</validator>
	<validator>
		<validator-id>validaNumeroDocumento</validator-id>
		<validator-class>br.com.mulato.cso.view.validation.NumeroDocValidation</validator-class>
	</validator>

	<!-- APPLICATION -->
	<application>
		<message-bundle>Rotulos</message-bundle>
		<locale-config>
			<default-locale>pt_BR</default-locale>
			<supported-locale>pt_BR</supported-locale>
		</locale-config>
	</application>

	<!-- LISTENER -->
	<lifecycle>
		<phase-listener>br.com.mulato.cso.view.listener.PageListener</phase-listener>
	</lifecycle>
</faces-config>
