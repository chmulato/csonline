		</navigation-case>
		<navigation-case>
			<from-outcome>delivery</from-outcome>
			<to-view-id>/delivery.faces</to-view-id>
		</navigation-case>
		<navigation-case>
			<from-outcome>deliveries</from-outcome>
			<to-view-id>/deliveries.faces</to-view-id>
		</navigation-case>
	</navigation-rule>

	<navigation-rule>
		<from-view-id>/delivery_customer.xhtml</from-view-id>
		<navigation-case>
			<from-outcome>resume</from-outcome>
			<to-view-id>/resume.faces</to-view-id>
		</navigation-case>
		<navigation-case>
			<from-outcome>delivery_customer</from-outcome>
			<to-view-id>/delivery_customer.faces</to-view-id>
		</navigation-case>
		<navigation-case>
			<from-outcome>deliveries</from-outcome>
			<to-view-id>/deliveries.faces</to-view-id>
		</navigation-case>
	</navigation-rule>

	<navigation-rule>
		<from-view-id>/delivery_courier.xhtml</from-view-id>
		<navigation-case>
			<from-outcome>resume</from-outcome>
			<to-view-id>/resume.faces</to-view-id>
		</navigation-case>
		<navigation-case>
			<from-outcome>delivery_courier</from-outcome>
			<to-view-id>/delivery_courier.faces</to-view-id>
		</navigation-case>
		<navigation-case>
			<from-outcome>deliveries</from-outcome>
			<to-view-id>/deliveries.faces</to-view-id>
		</navigation-case>
	</navigation-rule>

	<navigation-rule>
		<from-view-id>/deliveries_completed.xhtml</from-view-id>
		<navigation-case>
			<from-outcome>login</from-outcome>
			<to-view-id>/login.faces</to-view-id>
		</navigation-case>
		<navigation-case>
			<from-outcome>delivery_view</from-outcome>
			<to-view-id>/delivery_view.faces</to-view-id>
		</navigation-case>
	</navigation-rule>

	<navigation-rule>
		<from-view-id>/delivery_view.xhtml</from-view-id>
		<navigation-case>
			<from-outcome>resume</from-outcome>
			<to-view-id>/resume.faces</to-view-id>
		</navigation-case>
		<navigation-case>
			<from-outcome>delivery_view</from-outcome>
			<to-view-id>/delivery_view.faces</to-view-id>
		</navigation-case>
		<navigation-case>
