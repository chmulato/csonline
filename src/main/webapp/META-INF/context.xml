<?xml version="1.0" encoding="UTF-8"?>
<Context path="/csonline">
	<!--
		JNDI/DataSource não utilizado neste projeto.
		
		A aplicação CSOnline conecta diretamente ao banco via JDBC no código Java 
		(DatabaseInitializer), sem dependência de configurações do servidor.
		
		Tecnologias atuais:
		- Jakarta EE 10 com Jetty 11 (desenvolvimento)
		- H2 Database 2.3.232 (inicialização automática)
		- Conexão direta via JDBC (sem JNDI)
		
		Isso simplifica o deploy e torna a aplicação independente do servidor.
	-->
</Context>
